<Window x:Class="NoteBoardWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Note Board"
        Width="408"
        Height="356"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border x:Name="Card"
            Margin="14"
            Padding="18"
            CornerRadius="30"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            MouseLeftButtonDown="Card_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#B8000000" Opacity="0.42" />
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FFF2D879" />
                <GradientStop Offset="0.52" Color="#FFEFB85B" />
                <GradientStop Offset="1" Color="#FFD99844" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse Width="12" Height="12" Fill="#FF7A531A" VerticalAlignment="Center" />
                <TextBlock x:Name="TitleText"
                           Grid.Column="1"
                           Margin="10,0,0,0"
                           Text="Заметка"
                           FontSize="21"
                           FontWeight="SemiBold"
                           Foreground="#40270B" />
                <Button Grid.Column="2"
                        Width="32"
                        Height="32"
                        Background="#1E000000"
                        Foreground="#4F2F08"
                        BorderThickness="0"
                        FontSize="18"
                        FontWeight="Bold"
                        Content="×"
                        Click="CloseButton_Click" />
            </Grid>

            <TextBox x:Name="NoteTextBox"
                     Grid.Row="1"
                     Margin="0,14,0,0"
                     Padding="16"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     FontSize="16"
                     Background="#18FFFFFF"
                     BorderBrush="#16FFFFFF"
                     BorderThickness="1"
                     Foreground="#3D2408"
                     TextChanged="NoteTextBox_TextChanged" />

            <TextBlock x:Name="StatusText"
                       Grid.Row="2"
                       Margin="0,12,0,0"
                       Foreground="#70481B"
                       Text="Готово."
                       TextWrapping="Wrap" />
        </Grid>
    </Border>
</Window>
