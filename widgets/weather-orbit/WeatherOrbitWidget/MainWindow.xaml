<Window x:Class="WeatherOrbitWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather Orbit"
        Width="472"
        Height="478"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border x:Name="Card"
            Margin="14"
            Padding="18"
            CornerRadius="32"
            BorderBrush="#30FFFFFF"
            BorderThickness="1"
            MouseLeftButtonDown="Card_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#C0000000" Opacity="0.48" />
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="GradientA" Offset="0" Color="#FF0E2940" />
                <GradientStop x:Name="GradientB" Offset="0.56" Color="#FF235882" />
                <GradientStop x:Name="GradientC" Offset="1" Color="#FF101F32" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="LocationText"
                               Text="Погода"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="UpdatedText"
                               Text="Подготавливаю виджет..."
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#BBD0E5"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button x:Name="RefreshButton"
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        Padding="12,8"
                        Background="#18293B"
                        Foreground="White"
                        BorderThickness="0"
                        Content="Обновить"
                        Click="RefreshButton_Click" />

                <Button x:Name="CloseButton"
                        Grid.Column="2"
                        Margin="10,0,0,0"
                        Width="34"
                        Height="34"
                        Background="#16000000"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="18"
                        FontWeight="Bold"
                        Content="×"
                        Click="CloseButton_Click" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="176" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,14,0">
                    <TextBlock x:Name="TemperatureText"
                               Text="--°"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock x:Name="ConditionText"
                               Text="Жду данные"
                               FontSize="18"
                               Foreground="#F0F7FF"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="FeelsLikeText"
                               Text="Ощущается как --°"
                               Margin="0,8,0,0"
                               Foreground="#C7D9EA"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="LocationMetaText"
                               Text="Локация не выбрана"
                               Margin="0,8,0,0"
                               Foreground="#A8C1D8"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="8"
                        Background="#18000000"
                        CornerRadius="26">
                    <Canvas x:Name="SceneCanvas"
                            Width="160"
                            Height="144"
                            MouseLeftButtonDown="SceneCanvas_MouseLeftButtonDown">
                        <Ellipse x:Name="SkyGlow"
                                 Width="130"
                                 Height="130"
                                 Canvas.Left="14"
                                 Canvas.Top="4"
                                 Fill="#40A7E8FF"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="SunOrb"
                                 Width="56"
                                 Height="56"
                                 Canvas.Left="82"
                                 Canvas.Top="16"
                                 Fill="#FFF6C65D"
                                 Stroke="#66FFF8E1"
                                 StrokeThickness="2"
                                 MouseLeftButtonDown="SunOrb_MouseLeftButtonDown"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <RotateTransform />
                                </TransformGroup>
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="MoonOrb"
                                 Width="46"
                                 Height="46"
                                 Canvas.Left="86"
                                 Canvas.Top="18"
                                 Fill="#FFEAF2FF"
                                 Stroke="#66FFFFFF"
                                 StrokeThickness="1.5"
                                 Visibility="Collapsed"
                                 MouseLeftButtonDown="MoonOrb_MouseLeftButtonDown"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <RotateTransform />
                                </TransformGroup>
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Border x:Name="CloudOne"
                                Width="94"
                                Height="36"
                                CornerRadius="18"
                                Background="#D8EAF7FF"
                                Canvas.Left="18"
                                Canvas.Top="58"
                                MouseLeftButtonDown="Cloud_MouseLeftButtonDown"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform />
                            </Border.RenderTransform>
                        </Border>

                        <Border x:Name="CloudTwo"
                                Width="66"
                                Height="28"
                                CornerRadius="14"
                                Background="#BFE2F8FF"
                                Canvas.Left="86"
                                Canvas.Top="80"
                                MouseLeftButtonDown="Cloud_MouseLeftButtonDown"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform />
                            </Border.RenderTransform>
                        </Border>

                        <Ellipse x:Name="RainAccent"
                                 Width="13"
                                 Height="19"
                                 Canvas.Left="100"
                                 Canvas.Top="108"
                                 Fill="#90B4FFFF"
                                 Visibility="Collapsed" />
                    </Canvas>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="#16000000" CornerRadius="18" Padding="11" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="Ветер" Foreground="#A8C1D8" />
                        <TextBlock x:Name="WindText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#16000000" CornerRadius="18" Padding="11" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="Влажность" Foreground="#A8C1D8" />
                        <TextBlock x:Name="HumidityText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#16000000" CornerRadius="18" Padding="11" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="Давление" Foreground="#A8C1D8" />
                        <TextBlock x:Name="PressureText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#16000000" CornerRadius="18" Padding="11" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Облачность" Foreground="#A8C1D8" />
                        <TextBlock x:Name="CloudText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#16000000" CornerRadius="18" Padding="11" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Осадки" Foreground="#A8C1D8" />
                        <TextBlock x:Name="PrecipitationText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Background="#16000000" CornerRadius="18" Padding="11" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Ощущается" Foreground="#A8C1D8" />
                        <TextBlock x:Name="FeelsLikeTileText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="2" Background="#16000000" CornerRadius="18" Padding="11" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Восход" Foreground="#A8C1D8" />
                        <TextBlock x:Name="SunriseText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="3" Background="#16000000" CornerRadius="18" Padding="11">
                    <StackPanel>
                        <TextBlock Text="Закат" Foreground="#A8C1D8" />
                        <TextBlock x:Name="SunsetText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="StatusText"
                       Grid.Row="3"
                       Margin="0,14,0,0"
                       Foreground="#C9D9E8"
                       TextWrapping="Wrap"
                       Text="Готово." />
        </Grid>
    </Border>
</Window>
