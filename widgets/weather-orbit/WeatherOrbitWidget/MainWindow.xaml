<Window x:Class="WeatherOrbitWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather Orbit"
        Width="420"
        Height="330"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border x:Name="Card"
            Margin="14"
            Padding="18"
            CornerRadius="28"
            BorderBrush="#30FFFFFF"
            BorderThickness="1"
            MouseLeftButtonDown="Card_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#B0000000" Opacity="0.45" />
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="GradientA" Offset="0" Color="#FF0E2940" />
                <GradientStop x:Name="GradientB" Offset="0.55" Color="#FF235882" />
                <GradientStop x:Name="GradientC" Offset="1" Color="#FF11263A" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="LocationText" Text="Погода" FontSize="22" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="UpdatedText" Text="Обновляю..." Foreground="#BBD0E5" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>

                <Button x:Name="RefreshButton"
                        Grid.Column="1"
                        Padding="12,8"
                        Background="#18293B"
                        Foreground="White"
                        BorderThickness="0"
                        Content="Обновить"
                        Click="RefreshButton_Click" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TemperatureText" Text="--°" FontSize="56" FontWeight="Bold" Foreground="White" />
                    <TextBlock x:Name="ConditionText" Text="Жду данные" FontSize="18" Foreground="#E8F3FF" />
                    <TextBlock x:Name="FeelsLikeText" Text="Ощущается как --°" Margin="0,6,0,0" Foreground="#BBD0E5" />
                </StackPanel>

                <Border Grid.Column="1" Background="#19000000" CornerRadius="24" Padding="8">
                    <Canvas x:Name="SceneCanvas"
                            Width="150"
                            Height="126"
                            MouseLeftButtonDown="SceneCanvas_MouseLeftButtonDown">
                        <Ellipse x:Name="SkyGlow"
                                 Width="120"
                                 Height="120"
                                 Canvas.Left="16"
                                 Canvas.Top="4"
                                 Fill="#40A7E8FF"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="SunOrb"
                                 Width="54"
                                 Height="54"
                                 Canvas.Left="76"
                                 Canvas.Top="16"
                                 Fill="#FFF6C65D"
                                 Stroke="#66FFF8E1"
                                 StrokeThickness="2"
                                 MouseLeftButtonDown="SunOrb_MouseLeftButtonDown"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <RotateTransform />
                                </TransformGroup>
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="MoonOrb"
                                 Width="44"
                                 Height="44"
                                 Canvas.Left="82"
                                 Canvas.Top="18"
                                 Fill="#FFEAF2FF"
                                 Stroke="#66FFFFFF"
                                 StrokeThickness="1.5"
                                 Visibility="Collapsed"
                                 MouseLeftButtonDown="MoonOrb_MouseLeftButtonDown"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <RotateTransform />
                                </TransformGroup>
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Border x:Name="CloudOne"
                                Width="86"
                                Height="34"
                                CornerRadius="17"
                                Background="#D8EAF7FF"
                                Canvas.Left="28"
                                Canvas.Top="52"
                                MouseLeftButtonDown="Cloud_MouseLeftButtonDown"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform />
                            </Border.RenderTransform>
                        </Border>

                        <Border x:Name="CloudTwo"
                                Width="62"
                                Height="26"
                                CornerRadius="13"
                                Background="#BFE2F8FF"
                                Canvas.Left="72"
                                Canvas.Top="72"
                                MouseLeftButtonDown="Cloud_MouseLeftButtonDown"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform />
                            </Border.RenderTransform>
                        </Border>

                        <Ellipse x:Name="RainAccent"
                                 Width="12"
                                 Height="18"
                                 Canvas.Left="92"
                                 Canvas.Top="98"
                                 Fill="#90B4FFFF"
                                 Visibility="Collapsed" />
                    </Canvas>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="#16000000" CornerRadius="18" Padding="12" Margin="0,0,5,5">
                    <StackPanel>
                        <TextBlock Text="Ветер" Foreground="#A8C1D8" />
                        <TextBlock x:Name="WindText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#16000000" CornerRadius="18" Padding="12" Margin="5,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Влажность" Foreground="#A8C1D8" />
                        <TextBlock x:Name="HumidityText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#16000000" CornerRadius="18" Padding="12" Margin="0,5,5,0">
                    <StackPanel>
                        <TextBlock Text="Осадки" Foreground="#A8C1D8" />
                        <TextBlock x:Name="PrecipitationText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Background="#16000000" CornerRadius="18" Padding="12" Margin="5,5,0,0">
                    <StackPanel>
                        <TextBlock Text="Солнце" Foreground="#A8C1D8" />
                        <TextBlock x:Name="SunTimeText" Margin="0,4,0,0" Text="--" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="StatusText"
                       Grid.Row="3"
                       Margin="0,14,0,0"
                       Foreground="#C9D9E8"
                       TextTrimming="CharacterEllipsis"
                       Text="Готово." />
        </Grid>
    </Border>
</Window>
