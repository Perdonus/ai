{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop AI Agent",
  "version": "0.1.0",
  "identifier": "ru.sosiskibot.desktop-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Desktop AI Agent",
        "width": 980,
        "height": 780,
        "visible": true,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": []
  }
}

