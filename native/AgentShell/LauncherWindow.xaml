<Window
    x:Class="AgentShell.LauncherWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d">
    <Grid Background="#010203">
        <Border
            x:Name="ShellPanel"
            Margin="0"
            Padding="12"
            Background="#0A1017"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="30"
            HorizontalAlignment="Stretch">
            <Grid RowDefinitions="Auto,Auto">
                <TextBox
                    x:Name="PromptBox"
                    Height="48"
                    Padding="16,10,16,10"
                    VerticalContentAlignment="Center"
                    automation:AutomationProperties.AutomationId="PromptBox"
                    PlaceholderText="Напиши действие"
                    FontSize="17"
                    Background="#121A25"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="23"
                    Foreground="{StaticResource ShellTextBrush}"
                    KeyDown="PromptBox_KeyDown" />

                <Border
                    x:Name="ConversationContainer"
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Padding="8"
                    Background="#0F1722"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="24"
                    Visibility="Collapsed">
                    <ScrollViewer
                    x:Name="ConversationScrollViewer"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ConversationPanel" Spacing="10" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
