<Window
    x:Class="AgentShell.LauncherWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Border
            x:Name="ShellPanel"
            Width="456"
            Padding="10"
            Background="#0B1118"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="28">
            <Grid RowDefinitions="Auto,Auto">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox
                        x:Name="PromptBox"
                        Height="44"
                        Padding="16,0"
                        PlaceholderText="Напиши действие"
                        FontSize="18"
                        Background="#121A24"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="22"
                        Foreground="{StaticResource ShellTextBrush}"
                        KeyDown="PromptBox_KeyDown" />
                    <Button
                        x:Name="SettingsButton"
                        Grid.Column="1"
                        Width="44"
                        Height="44"
                        Margin="10,0,0,0"
                        Padding="0"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="14"
                        Content="&#xE713;"
                        Background="#17202C"
                        Foreground="{StaticResource ShellTextBrush}"
                        Click="SettingsButton_Click" />
                </Grid>

                <Border
                    x:Name="OutputContainer"
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Padding="14"
                    Background="#111925"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="22"
                    Visibility="Collapsed">
                    <Grid>
                        <ProgressRing
                            x:Name="BusyRing"
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            IsActive="False"
                            Visibility="Collapsed"
                            Foreground="{StaticResource ShellAccentBrush}" />
                        <TextBlock x:Name="StatusText" Visibility="Collapsed" />
                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="14">
                                <StackPanel x:Name="ThinkingPanel" Visibility="Collapsed" Spacing="6">
                                    <TextBlock
                                        x:Name="ThinkingText"
                                        TextWrapping="WrapWholeWords"
                                        Foreground="#D1D9E5"
                                        FontSize="13" />
                                </StackPanel>
                                <StackPanel x:Name="AnswerPanel" Visibility="Collapsed" Spacing="6">
                                    <TextBlock
                                        x:Name="AnswerText"
                                        TextWrapping="WrapWholeWords"
                                        Foreground="{StaticResource ShellTextBrush}"
                                        FontSize="14" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="ErrorText"
                                    Visibility="Collapsed"
                                    TextWrapping="WrapWholeWords"
                                    Foreground="#FF9F9F"
                                    FontSize="13" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
