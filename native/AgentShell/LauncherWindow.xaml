<Window
    x:Class="AgentShell.LauncherWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Border
            x:Name="ShellPanel"
            Width="520"
            Padding="22"
            Background="#0B1118"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="30">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <ProgressRing
                        x:Name="BusyRing"
                        Width="18"
                        Height="18"
                        Margin="0,2,10,0"
                        IsActive="False"
                        Foreground="{StaticResource ShellAccentBrush}"
                        VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            Text="AI Agent"
                            Foreground="{StaticResource ShellAccentBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Opacity="0.96" />
                        <TextBlock
                            x:Name="StatusText"
                            Margin="0,4,0,0"
                            Text="Ready"
                            Foreground="#8FA6BE"
                            FontSize="12" />
                    </StackPanel>
                    <Button
                        x:Name="SettingsButton"
                        Grid.Column="2"
                        Width="34"
                        Height="34"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="14"
                        Content="&#xE713;"
                        Background="#17202C"
                        Foreground="{StaticResource ShellTextBrush}"
                        Click="SettingsButton_Click" />
                </Grid>

                <Border
                    Grid.Row="1"
                    Margin="0,16,0,0"
                    Padding="14"
                    Background="#111925"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="22">
                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14">
                            <StackPanel x:Name="ThinkingPanel" Visibility="Collapsed" Spacing="6">
                                <TextBlock
                                    Text="Размышления"
                                    Foreground="{StaticResource ShellAccentBrush}"
                                    FontSize="12"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    x:Name="ThinkingText"
                                    TextWrapping="WrapWholeWords"
                                    Foreground="#D1D9E5"
                                    FontSize="13" />
                            </StackPanel>
                            <StackPanel x:Name="AnswerPanel" Visibility="Collapsed" Spacing="6">
                                <TextBlock
                                    Text="Ответ"
                                    Foreground="#9FD0FF"
                                    FontSize="12"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    x:Name="AnswerText"
                                    TextWrapping="WrapWholeWords"
                                    Foreground="{StaticResource ShellTextBrush}"
                                    FontSize="14" />
                            </StackPanel>
                            <TextBlock
                                x:Name="ErrorText"
                                Visibility="Collapsed"
                                TextWrapping="WrapWholeWords"
                                Foreground="#FF9F9F"
                                FontSize="13" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="*,Auto">
                    <TextBox
                        x:Name="PromptBox"
                        Margin="0,0,10,0"
                        Height="44"
                        Padding="14,0"
                        PlaceholderText="Напиши действие"
                        FontSize="18"
                        KeyDown="PromptBox_KeyDown" />
                    <Button
                        x:Name="SendButton"
                        Grid.Column="1"
                        Width="44"
                        Height="44"
                        Padding="0"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="16"
                        Content="&#xE122;"
                        Background="{StaticResource ShellAccentBrush}"
                        Foreground="#081018"
                        Click="SendButton_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
