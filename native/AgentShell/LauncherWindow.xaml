<Window
    x:Class="AgentShell.LauncherWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Border
            x:Name="ShellPanel"
            Width="480"
            Padding="10"
            Background="#0A1017"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="30">
            <Grid RowDefinitions="Auto,Auto">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox
                        x:Name="PromptBox"
                        Height="46"
                        Padding="16,0"
                        automation:AutomationProperties.AutomationId="PromptBox"
                        PlaceholderText="Напиши действие"
                        FontSize="17"
                        Background="#121A25"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="23"
                        Foreground="{StaticResource ShellTextBrush}"
                        KeyDown="PromptBox_KeyDown" />
                    <Button
                        x:Name="SettingsButton"
                        Grid.Column="1"
                        Width="46"
                        Height="46"
                        Margin="10,0,0,0"
                        Padding="0"
                        automation:AutomationProperties.AutomationId="SettingsButton"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="15"
                        Content="&#xE713;"
                        Background="#121A25"
                        Foreground="{StaticResource ShellTextBrush}"
                        Click="SettingsButton_Click" />
                </Grid>

                <Border
                    x:Name="ConversationContainer"
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Padding="8"
                    Background="#0F1722"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="24"
                    Visibility="Collapsed">
                    <ScrollViewer
                        x:Name="ConversationScrollViewer"
                        MaxHeight="320"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ConversationPanel" Spacing="10" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
