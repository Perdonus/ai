<Application
    x:Class="AgentShell.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <Color x:Key="ShellAccentColor">#FF90F0D0</Color>
            <Color x:Key="ShellPanelColor">#FF0E141D</Color>
            <Color x:Key="ShellPanelEdgeColor">#FF1E2938</Color>
            <Color x:Key="ShellTextColor">#FFF5FBFF</Color>
            <SolidColorBrush x:Key="ShellAccentBrush" Color="{StaticResource ShellAccentColor}" />
            <SolidColorBrush x:Key="ShellPanelBrush" Color="{StaticResource ShellPanelColor}" />
            <SolidColorBrush x:Key="ShellPanelEdgeBrush" Color="{StaticResource ShellPanelEdgeColor}" />
            <SolidColorBrush x:Key="ShellTextBrush" Color="{StaticResource ShellTextColor}" />
            <SolidColorBrush x:Key="FocusVisualPrimaryBrush" Color="Transparent" />
            <SolidColorBrush x:Key="FocusVisualSecondaryBrush" Color="Transparent" />
            <Style TargetType="Control">
                <Setter Property="UseSystemFocusVisuals" Value="False" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="Background" Value="#182230" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextBrush}" />
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="#171F2B" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextBrush}" />
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="#171F2B" />
                <Setter Property="Foreground" Value="{StaticResource ShellTextBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
