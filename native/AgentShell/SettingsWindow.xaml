<Window
    x:Class="AgentShell.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AgentShell.Models"
    mc:Ignorable="d">
    <Grid Background="#09111A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#111925" Padding="20">
            <StackPanel Spacing="10">
                <TextBlock Text="Настройки агента" FontSize="22" FontWeight="SemiBold" Foreground="White" />
                <Button Content="Провайдеры" Click="ProvidersTabButton_Click" />
                <Button Content="Модели" Click="ModelsTabButton_Click" />
                <Button Content="Тулзы" Click="ToolsTabButton_Click" />
                <Button Content="Виджеты" Click="WidgetsTabButton_Click" />
                <Button Margin="0,18,0,0" Content="Сохранить" Click="SaveButton_Click" />
                <Button Content="Бэкап" Click="BackupButton_Click" />
                <Button Content="Экспорт" Click="ExportButton_Click" />
                <Button Content="Восстановить последний" Click="RestoreButton_Click" />
                <TextBlock x:Name="OperationStatusText" Margin="0,10,0,0" Foreground="#8FA6BE" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Padding="26">
            <ScrollViewer x:Name="ProvidersView" Visibility="Visible">
                <StackPanel Spacing="14">
                    <TextBlock Text="Провайдеры" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Только API-ключи. Базовые URL провайдеров уже зашиты в приложение." Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                    <ItemsControl x:Name="ProvidersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ProviderDescriptor">
                                <Border Background="#131D2A" CornerRadius="22" Padding="16" Margin="0,0,0,10">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{x:Bind Name}" FontSize="18" Foreground="White" />
                                        <TextBox
                                            Tag="{x:Bind Id}"
                                            PlaceholderText="API key"
                                            Loaded="ProviderApiKeyBox_Loaded"
                                            TextChanged="ProviderApiKeyBox_TextChanged"
                                            LostFocus="ProviderApiKeyBox_LostFocus" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ModelsView" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Модели" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <Border Background="#131D2A" CornerRadius="22" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Основная модель" FontSize="18" Foreground="White" />
                            <ComboBox x:Name="PrimaryProviderCombo" SelectionChanged="PrimaryProviderCombo_SelectionChanged" />
                            <ComboBox x:Name="PrimaryModelCombo" />
                            <CheckBox x:Name="PrimaryThinkingToggle" Content="Показывать размышления основной модели" />

                            <CheckBox x:Name="SeparateAnalysisToggle" Content="Отдельная модель анализа" Checked="SeparateToggle_Changed" Unchecked="SeparateToggle_Changed" />
                            <StackPanel x:Name="AnalysisPanel" Spacing="10">
                                <ComboBox x:Name="AnalysisProviderCombo" SelectionChanged="AnalysisProviderCombo_SelectionChanged" />
                                <ComboBox x:Name="AnalysisModelCombo" />
                                <CheckBox x:Name="AnalysisThinkingToggle" Content="Показывать размышления модели анализа" />
                            </StackPanel>

                            <CheckBox x:Name="SeparateVisionToggle" Content="Отдельная vision-модель" Checked="SeparateToggle_Changed" Unchecked="SeparateToggle_Changed" />
                            <StackPanel x:Name="VisionPanel" Spacing="10">
                                <ComboBox x:Name="VisionProviderCombo" SelectionChanged="VisionProviderCombo_SelectionChanged" />
                                <ComboBox x:Name="VisionModelCombo" />
                            </StackPanel>

                            <CheckBox x:Name="SeparateOcrToggle" Content="Отдельная OCR-модель" Checked="SeparateToggle_Changed" Unchecked="SeparateToggle_Changed" />
                            <StackPanel x:Name="OcrPanel" Spacing="10">
                                <ComboBox x:Name="OcrProviderCombo" SelectionChanged="OcrProviderCombo_SelectionChanged" />
                                <ComboBox x:Name="OcrModelCombo" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ToolsView" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Тулзы" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <ItemsControl x:Name="ToolsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:RuntimeItem">
                                <Border Background="#131D2A" CornerRadius="20" Padding="16" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Name}" Foreground="White" FontSize="18" />
                                            <TextBlock Text="{x:Bind Description}" Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Margin="10,0,0,0" Content="Настройки" IsEnabled="{x:Bind HasSettings}" />
                                        <Button Grid.Column="2" Margin="10,0,0,0" Content="Удалить" Click="RemoveTool_Click" Tag="{x:Bind RootPath}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="WidgetsView" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Виджеты" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Виджеты могут принимать данные от агента, если это объявлено в их манифесте." Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                    <ItemsControl x:Name="WidgetsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:RuntimeItem">
                                <Border Background="#131D2A" CornerRadius="20" Padding="16" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Name}" Foreground="White" FontSize="18" />
                                            <TextBlock Text="{x:Bind Description}" Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Margin="10,0,0,0" Content="Тест" Click="TestWidget_Click" Tag="{x:Bind RootPath}" />
                                        <Button Grid.Column="2" Margin="10,0,0,0" Content="Настройки" IsEnabled="{x:Bind HasSettings}" />
                                        <Button Grid.Column="3" Margin="10,0,0,0" Content="Удалить" Click="RemoveWidget_Click" Tag="{x:Bind RootPath}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
