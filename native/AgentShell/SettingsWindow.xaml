<Window
    x:Class="AgentShell.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AgentShell.Models"
    xmlns:services="using:AgentShell.Services"
    mc:Ignorable="d">
    <Window.Resources>
        <services:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DataTemplate x:Key="ModelChoiceTemplate" x:DataType="models:ModelChoice">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{x:Bind DisplayName}" Foreground="White" VerticalAlignment="Center" />
                <Border
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="8,2"
                    Background="#214F3E"
                    CornerRadius="999"
                    Visibility="{Binding ShowThinkingTag, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind ThinkingTagText}" FontSize="11" Foreground="#DFFFE7" />
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#09111A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#111925" Padding="20">
            <StackPanel Spacing="10">
                <TextBlock Text="Настройки агента" FontSize="22" FontWeight="SemiBold" Foreground="White" />
                <Button Content="Провайдеры" Click="ProvidersTabButton_Click" />
                <Button Content="Локальные ИИ" Click="LocalAiTabButton_Click" />
                <Button Content="Модели" Click="ModelsTabButton_Click" />
                <Button Content="Тулзы" Click="ToolsTabButton_Click" />
                <Button Content="Виджеты" Click="WidgetsTabButton_Click" />
                <Button Margin="0,18,0,0" Content="Сохранить" Click="SaveButton_Click" />
                <Button Content="Бэкап" Click="BackupButton_Click" />
                <Button Content="Экспорт" Click="ExportButton_Click" />
                <Button Content="Восстановить последний" Click="RestoreButton_Click" />
                <TextBlock x:Name="OperationStatusText" Margin="0,10,0,0" Foreground="#8FA6BE" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Padding="26">
            <ScrollViewer x:Name="ProvidersView" Visibility="Visible">
                <StackPanel Spacing="14">
                    <TextBlock Text="Провайдеры" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Здесь только API-ключи. Базовые URL уже встроены в приложение." Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                    <ItemsControl x:Name="ProvidersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ProviderDescriptor">
                                <Border Background="#131D2A" CornerRadius="22" Padding="16" Margin="0,0,0,10">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{x:Bind Name}" FontSize="18" Foreground="White" />
                                        <TextBox
                                            Tag="{x:Bind Id}"
                                            PlaceholderText="API key"
                                            Loaded="ProviderApiKeyBox_Loaded"
                                            TextChanged="ProviderApiKeyBox_TextChanged"
                                            LostFocus="ProviderApiKeyBox_LostFocus" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="LocalAiView" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Локальные ИИ" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Для встроенного local inference используется llama.cpp и GGUF-модели. Модель поднимается только по запросу и выгружается после простоя." Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                    <Border Background="#131D2A" CornerRadius="22" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Выгружать после простоя, секунд" Foreground="White" />
                            <TextBox x:Name="LocalIdleSecondsBox" PlaceholderText="60" LostFocus="LocalIdleSecondsBox_LostFocus" />
                        </StackPanel>
                    </Border>

                    <Border Background="#131D2A" CornerRadius="22" Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Добавить GGUF-модель" FontSize="18" Foreground="White" />
                            <TextBox x:Name="LocalModelNameBox" PlaceholderText="Название модели" />
                            <TextBox x:Name="LocalModelPathBox" PlaceholderText="Полный путь к .gguf" />
                            <Grid ColumnDefinitions="*,*">
                                <TextBox x:Name="LocalModelContextBox" PlaceholderText="Context size, например 4096" />
                                <TextBox x:Name="LocalModelGpuLayersBox" Grid.Column="1" Margin="10,0,0,0" PlaceholderText="GPU layers, например 0" />
                            </Grid>
                            <CheckBox x:Name="LocalModelSupportsThinkingToggle" Content="Модель поддерживает native thinking" />
                            <Button Content="Добавить локальную модель" Click="AddLocalModel_Click" />
                        </StackPanel>
                    </Border>

                    <ItemsControl x:Name="LocalModelsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:LocalModelConfig">
                                <Border Background="#131D2A" CornerRadius="20" Padding="16" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind Name}" Foreground="White" FontSize="18" />
                                                <Border
                                                    Padding="8,2"
                                                    Background="#214F3E"
                                                    CornerRadius="999"
                                                    Visibility="{Binding SupportsThinking, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="think" FontSize="11" Foreground="#DFFFE7" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind ModelPath}" Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind ContextSummary}" Foreground="#8FA6BE" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Margin="10,0,0,0" Content="Удалить" Click="RemoveLocalModel_Click" Tag="{x:Bind Id}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ModelsView" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Модели" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="OCR встроен в приложение и работает через Tesseract OCR, отдельную OCR-модель выбирать не нужно." Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                    <Border Background="#131D2A" CornerRadius="22" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Основная модель" FontSize="18" Foreground="White" />
                            <ComboBox x:Name="PrimaryProviderCombo" SelectionChanged="PrimaryProviderCombo_SelectionChanged" />
                            <ComboBox x:Name="PrimaryModelCombo" SelectionChanged="ModelSelectionChanged" ItemTemplate="{StaticResource ModelChoiceTemplate}" />
                            <CheckBox x:Name="PrimaryThinkingToggle" Content="Native thinking" Checked="ModelSetting_Changed" Unchecked="ModelSetting_Changed" />
                            <CheckBox x:Name="PrimaryMcpThinkingToggle" Content="MCP thinking" Checked="ModelSetting_Changed" Unchecked="ModelSetting_Changed" />

                            <CheckBox x:Name="SeparateAnalysisToggle" Content="Использовать отдельную модель-планировщик" Checked="SeparateToggle_Changed" Unchecked="SeparateToggle_Changed" />
                            <StackPanel x:Name="AnalysisPanel" Spacing="10">
                                <ComboBox x:Name="AnalysisProviderCombo" SelectionChanged="AnalysisProviderCombo_SelectionChanged" />
                                <ComboBox x:Name="AnalysisModelCombo" SelectionChanged="ModelSelectionChanged" ItemTemplate="{StaticResource ModelChoiceTemplate}" />
                                <CheckBox x:Name="AnalysisThinkingToggle" Content="Native thinking" Checked="ModelSetting_Changed" Unchecked="ModelSetting_Changed" />
                                <CheckBox x:Name="AnalysisMcpThinkingToggle" Content="MCP thinking" Checked="ModelSetting_Changed" Unchecked="ModelSetting_Changed" />
                            </StackPanel>

                            <CheckBox x:Name="SeparateVisionToggle" Content="Использовать отдельную vision-модель" Checked="SeparateToggle_Changed" Unchecked="SeparateToggle_Changed" />
                            <StackPanel x:Name="VisionPanel" Spacing="10">
                                <ComboBox x:Name="VisionProviderCombo" SelectionChanged="VisionProviderCombo_SelectionChanged" />
                                <ComboBox x:Name="VisionModelCombo" SelectionChanged="ModelSelectionChanged" ItemTemplate="{StaticResource ModelChoiceTemplate}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ToolsView" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Тулзы" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <ItemsControl x:Name="ToolsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:RuntimeItem">
                                <Border Background="#131D2A" CornerRadius="20" Padding="16" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Name}" Foreground="White" FontSize="18" />
                                            <TextBlock Text="{x:Bind Description}" Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Margin="10,0,0,0" Content="Настройки" IsEnabled="{x:Bind HasSettings}" />
                                        <Button Grid.Column="2" Margin="10,0,0,0" Content="Удалить" Click="RemoveTool_Click" Tag="{x:Bind RootPath}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="WidgetsView" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Виджеты" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Виджеты могут принимать данные от агента, если это указано в их манифесте." Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                    <ItemsControl x:Name="WidgetsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:RuntimeItem">
                                <Border Background="#131D2A" CornerRadius="20" Padding="16" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Name}" Foreground="White" FontSize="18" />
                                            <TextBlock Text="{x:Bind Description}" Foreground="#A8B3C4" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Margin="10,0,0,0" Content="Тест" Click="TestWidget_Click" Tag="{x:Bind RootPath}" />
                                        <Button Grid.Column="2" Margin="10,0,0,0" Content="Настройки" IsEnabled="{x:Bind HasSettings}" />
                                        <Button Grid.Column="3" Margin="10,0,0,0" Content="Удалить" Click="RemoveWidget_Click" Tag="{x:Bind RootPath}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
